APP_NAME="Sistem K3 Monitoring"
APP_ENV=local
APP_KEY=                          # will be auto-generated on first docker compose up
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
# Gunakan nilai ini apa adanya untuk Docker. Sesuaikan jika deploy manual.
DB_CONNECTION=mysql
DB_HOST=mysql           # nama service di docker-compose.yml
DB_PORT=3306
DB_DATABASE=k3_db
DB_USERNAME=k3user
DB_PASSWORD=k3pass

# ── Session / Sanctum ─────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Domain yang boleh kirim request session (Sanctum SPA auth).
# Sesuaikan dengan port nginx di docker-compose (default 8080).
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080

# ── Integrasi TIF ─────────────────────────────────────────────────────────────
# Ganti dengan service key yang sudah disepakati bersama tim TIF.
# Kirimkan header "X-Service-Key: <nilai ini>" di setiap POST /api/violations.
TIF_SERVICE_KEY=GANTI_DENGAN_KEY_YANG_DISEPAKATI_TIF

# ── Telegram Notifications ───────────────────────────────────────────────────
# Bot token dari @BotFather.
# Jika dikosongkan, notifikasi tidak dikirim dan error dicatat di log.
TELEGRAM_BOT_TOKEN=

# Chat ID grup/user Manager (dapatkan via @userinfobot atau getUpdates).
TELEGRAM_MANAGER_CHAT_ID=

# Chat ID grup/user HR.
TELEGRAM_HR_CHAT_ID=

# ── Cache / Queue ─────────────────────────────────────────────────────────────
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ── Misc ──────────────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MAIL_MAILER=log